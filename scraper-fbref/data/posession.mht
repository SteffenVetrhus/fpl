@charset "utf-8";

html, body { margin: 0px; padding: 0px; font: 14px / 1.25 "Helvetica Neue", helvetica, arial, sans-serif; color: rgb(0, 0, 0); }

@media (prefers-reduced-motion: no-preference) {
  html:not(.backstop) { scroll-behavior: smooth; }
}

@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto !important; }
  * { animation: auto ease 0s 1 normal none running none !important; transition-duration: 0s !important; }
}

html:not(.backstop) div, html:not(.backstop) span { scroll-margin: 2.5em 0px 0px; }

body { position: relative; background: rgb(201, 203, 205); z-index: 0; text-size-adjust: none; }

a img { border: 0px; }

ul, li, ol { margin: 0px; padding: 0px; list-style-type: none; }

table th, table td { border: 0px; }

iframe { max-width: 100%; }

code { background: rgb(238, 238, 238); }

a, button, input, select, textarea, label, summary { touch-action: manipulation; }

::selection { background: rgb(255, 255, 0); text-shadow: none; }

html.no-js .hasmore, html.no-js .js, html.js .no-js, html.no-js button, html.is_build .hide_build, html.is_dev .hide_dev, html.is_live .hide_live { display: none !important; }

.js-select { visibility: hidden; }

a[href] { color: rgb(51, 68, 221); }

a[href]:visited { color: rgb(136, 68, 136); }

a[href]:hover { color: rgb(94, 68, 179); }

a[href]:active { color: rgb(187, 17, 34); }

a[href^="tel:"]::before { content: "ŌśÄ"; display: inline-block; margin-right: 0px; }

a[href^="mailto:"]::before { content: "Ō£ē"; display: inline-block; margin-right: 0px; }

.icon_group a[href^="tel:"]::before, .icon_group a[href^="mailto:"]::before { content: ""; }

.screen_only { display: initial; }

.user_logged_in .not_logged_in, .logged_in, .sr_cpi_control, .print_only { display: none; }

#perflog, #modernizr, .user_logged_in .logged_in { display: block; }

h2 { color: rgb(0, 0, 0); margin-bottom: 5px; font-size: 1.5em; }

img.right { float: right; margin: 0px 0px 5px 5px; }

img.left { float: left; margin: 0px 15px 15px 0px; }

sup { font-size: 0.75em; position: relative; top: -0.4em; vertical-align: baseline; }

.hidden-iso, .hidden, #content .hidden, .gutterad, .more, .print_only, #warnings.hide, #nag_devs { display: none; }

#inner_nav.hidden { visibility: hidden; }

.float_wrap { overflow: hidden; }

.grid2 { display: grid; column-gap: 10px; grid-template-columns: 1fr 1fr; }

.grid2 img { max-width: 100%; }

.grid2.heavyleft { grid-template-columns: 2fr 1fr; }

.grid2.heavyright { grid-template-columns: 1fr 2fr; }

#wrap { display: block; background: rgb(255, 255, 255); position: relative; }

#wrap > div, #wrap > ul { width: 100%; position: relative; clear: both; }

@media screen and (min-width: 1628px) {
  #wrap { width: 1600px; border-left: 1px solid rgb(116, 118, 120); border-right: 1px solid rgb(116, 118, 120); box-shadow: rgb(64, 69, 66) 0px 0px 27px; margin: 0px auto; }
  .sr_expanded > #wrap { width: 100%; border: 0px; box-shadow: none; }
}

@media screen and (min-width: 1328px) {
  .front_page #wrap { width: 1300px; border-left: 1px solid rgb(116, 118, 120); border-right: 1px solid rgb(116, 118, 120); box-shadow: rgb(64, 69, 66) 0px 0px 27px; margin: 0px auto; }
}

#header { overflow: visible; background: rgb(237, 239, 238); border-bottom: 3px solid rgb(2, 105, 55); min-height: 50px; }

#header img { height: 25px; float: left; padding: 8px 0px 8px 2%; max-width: calc(95% - 80px); }

#header #nav_trigger { display: block; cursor: pointer; float: right; padding: 7px 2% 7px 1%; height: 30px; }

#header #nav_trigger a { color: rgb(1, 55, 26); font-size: 20px; font-weight: bold; text-decoration: none; display: inline-block; }

#header #nav_trigger a::before { color: rgb(1, 55, 26); content: "Ōś░"; font-weight: normal; }

#header #nav { display: none; clear: both; width: 88%; background: rgb(255, 255, 255); padding: 7px 6% 0px; border-bottom: 3px solid rgb(1, 55, 26); border-top: 3px solid rgb(1, 55, 26); overflow: hidden; font-size: 12px; }

#header #nav .usertools { font-weight: bold; font-size: 12px; margin: 0px 0px 4px; padding: 7px 6% 0px; border-top: 1px solid rgb(201, 203, 205); }

#header #nav .breadcrumbs { font-size: 12px; padding: 7px 6%; border-top: 1px solid rgb(201, 203, 205); }

#header #nav_trigger.open { background: rgb(1, 55, 26); }

#header #nav_trigger.open a { color: rgb(255, 255, 255); }

#header #nav_trigger.open a::before { color: rgb(255, 255, 255); }

#header #nav.open { display: block; }

#header .social { margin: 15px 0px; display: none; }

#header.open_search { margin-bottom: 50px; }

#header #subnav { display: none; }

#header .search { margin-top: 10px; clear: both; padding: 0px 2% 6px; }

#header .search input, #header .search input:active, #header .search input:focus { height: 32px; font-size: 20px; }

.search input[type="search"] { padding: 4px 5px; border: 1px solid rgb(116, 118, 120); width: 73%; margin-right: 2%; }

.search input[type="search"].prefilled { background-color: rgb(255, 255, 170); }

.search input[type="submit"] { float: right; background: rgb(1, 55, 26); color: white; border: 1px solid rgb(116, 118, 120); padding: 0px; border-radius: 5px; height: 24px; width: calc(25% - 2px); }

.search input[type="submit"]:hover { text-decoration: underline; }

.search input[type="submit"]:active { background-color: rgb(64, 69, 66); }

.search .ac-outline { width: 73%; margin-right: 2%; }

.search .ac-outline input[type="search"] { width: 100%; margin: 0px; }

@media screen and (-webkit-min-device-pixel-ratio: 0) and (max-width: 400px) {
  #header .search input, #header .search input:active, #header .search input:focus { height: 32px; font-size: 20px; }
}

#wrap > #info { width: 96%; margin: 0px auto; padding-bottom: 10px; }

#info .opener, #info .opener:active, #inner_nav div .opener { color: rgb(153, 0, 0); font-weight: bold; clear: both; width: 100%; text-align: left; padding: 10px 0px; border: 0px; background: transparent; }

#info button#meta_more_button { border: 1px solid rgb(201, 203, 205); background-color: rgb(237, 239, 238); padding: 0.5em; margin: 0.5em 0px; text-align: center; width: 100%; max-width: 400px; text-overflow: ellipsis; white-space: nowrap; overflow: hidden; display: none; }

#info button#meta_more_button.show { display: inline-block; }

#info #meta > div > p:nth-child(n+6) { display: none; }

#info.open #meta > div > p:nth-child(n+6) { display: block; }

#info #meta .opener { display: none; }

#info #meta { margin-top: 10px; overflow: hidden; }

#info #meta p { font-size: 0.93em; margin: 3px 0px; }

#info #meta > div.media-item { float: right; margin-left: 10px; width: 70px; }

#info #meta > div.media-item.country { width: 100px; height: 75px; }

#info #meta > div.media-item.country .flag { width: 100%; height: 100%; background-size: 100%; }

#info .media-item img { width: 100%; height: auto; border: 1px solid black; box-sizing: border-box; }

#info .media-item img.additional { display: none; }

#info .media-item.logo img, .bbr #info .media-item img, .cbb #info .media-item img { border: 0px; }

#info #meta .media-item p { margin: 3px 0px; font-size: 0.785em; font-style: italic; }

#info #meta .media-item.loader p { visibility: hidden; }

#info h1 { margin-top: 0px; margin-bottom: 5px; line-height: 1.1em; font-size: 1.5em; }

#info h1 + p { margin-top: 5px; }

#info #bling { margin: 6px 1% 6px 0px; color: rgb(255, 255, 255); height: 24px; overflow: hidden; float: left; width: 88%; display: grid; gap: 5px 4px; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }

#info.teams #bling { width: 100%; }

#info #bling li { padding: 4px 1.25%; text-align: center; position: relative; height: 15px; background: rgb(1, 55, 26); font-size: 0.85em; word-spacing: 0px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; border-radius: 5px; display: inline-block; width: 27%; margin-bottom: 5px; }

#info.teams #bling li { width: 45%; }

#bling li a { color: inherit; position: relative; z-index: 1; }

#info #bling li.bling_hof { background-color: rgb(255, 219, 28); color: rgb(0, 0, 0); }

#info #bling li.bling_all_star { background-color: rgb(201, 203, 205); color: rgb(64, 69, 66); }

#info #bling li.bling_hof, #info.teams #bling li.bling_all_star, #info.teams #bling li.bling_champ { grid-column-end: span 2; }

