# Required: the public URL where Plausible will be accessible
BASE_URL=http://localhost:8000

# Required: secret key for session encryption (generate with: openssl rand -base64 48)
SECRET_KEY_BASE=

# Optional: port to expose Plausible on (default: 8010)
# PLAUSIBLE_PORT=8010

# Optional: disable public registration (default: invite_only)
# Options: true (open), invite_only, false (disabled)
# DISABLE_REGISTRATION=invite_only

# Optional: TOTP vault key for 2FA (generate with: openssl rand -base64 32)
# TOTP_VAULT_KEY=
