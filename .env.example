# FPL API Configuration
# Copy this file to .env and fill in your values

# Your FPL League ID
# Find it in the URL: https://fantasy.premierleague.com/leagues/YOUR_LEAGUE_ID/standings/c
FPL_LEAGUE_ID=

# Optional: FPL API Base URL (defaults to official API)
# FPL_API_BASE_URL=https://fantasy.premierleague.com/api

# Optional: Enable API request caching (recommended to avoid rate limits)
# ENABLE_API_CACHE=true

# Optional: Cache duration in seconds (default: 300 = 5 minutes)
# API_CACHE_DURATION=300

# =============================================
# PocketBase Authentication
# =============================================

# PocketBase URL for server-side requests (defaults to http://localhost:8090)
# In Docker, use the internal service name: http://pocketbase:8090
# POCKETBASE_URL=http://pocketbase:8090

# PocketBase URL for browser requests (defaults to POCKETBASE_URL)
# Set this when running in Docker so the browser can reach PocketBase
# POCKETBASE_PUBLIC_URL=http://localhost:8090

# PocketBase super admin credentials (for seed script and scrapers)
# PB_ADMIN_EMAIL=admin@fpl.local
# PB_ADMIN_PASSWORD=admin123456

# =============================================
# Stat Corner Scrapers
# =============================================

# Admin credentials used by the Python scraper services to write to PocketBase.
# These should match PB_ADMIN_EMAIL / PB_ADMIN_PASSWORD above.
# PB_ADMIN_EMAIL=admin@fpl.local
# PB_ADMIN_PASSWORD=admin123456

# =============================================
# News Aggregation
# =============================================

# Optional: News feed cache duration in seconds (default: 900 = 15 minutes)
# NEWS_CACHE_DURATION=900

# Optional: Twitter/X integration via third-party API (e.g., SociaVault free tier)
# Set an API key to enable tweet fetching alongside RSS feeds
# TWITTER_API_KEY=
# TWITTER_API_BASE_URL=https://api.sociavault.com/v1

# =============================================
# Analytics (Plausible)
# =============================================

# Self-hosted Plausible CE analytics (free, open-source, AGPL)
# Both variables are required to enable analytics.
# See https://github.com/plausible/community-edition for setup.
# PLAUSIBLE_DOMAIN=your-fpl-app.com
# PLAUSIBLE_SCRIPT_URL=https://your-plausible-instance.com/js/script.js
